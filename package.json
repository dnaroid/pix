{
  "name": "pi-ui-extend",
  "version": "0.1.66",
  "description": "Pix: a workspace-first terminal UI for Pi with tabs, readable tool activity, voice input, and bundled agent tools.",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnaroid/pix.git"
  },
  "homepage": "https://github.com/dnaroid/pix#readme",
  "bugs": {
    "url": "https://github.com/dnaroid/pix/issues"
  },
  "type": "module",
  "bin": {
    "pi-ui-extend": "./bin/pix.mjs",
    "pix": "./bin/pix.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js"
    },
    "./schemas/pix.json": "./schemas/pix.json",
    "./schemas/pi-tools-suite.json": "./schemas/pi-tools-suite.json"
  },
  "files": [
    "assets/screenshots",
    "bin",
    "docs",
    "dist",
    "schemas",
    "skills",
    "external/pi-tools-suite/index.ts",
    "external/pi-tools-suite/package.json",
    "external/pi-tools-suite/README.md",
    "external/pi-tools-suite/src",
    "external/pi-tools-suite/docs",
    "external/pi-tools-suite/licenses",
    "README.md"
  ],
  "scripts": {
    "predev": "npm run link:pix --silent",
    "dev": "mise exec node@24.16.0 -- tsx src/main.ts",
    "start": "mise exec node@24.16.0 -- tsx src/main.ts",
    "prebuild:pix": "npm run generate-schemas --silent",
    "build:pix": "mise exec node@24.16.0 -- tsc -p tsconfig.json",
    "prelink:pix": "npm run build:pix --silent",
    "link:pix": "mise exec node@24.16.0 -- npm link --silent",
    "watch:pix": "npm run link:pix --silent && mise exec node@24.16.0 -- tsc -p tsconfig.json --watch --preserveWatchOutput --noEmitOnError",
    "check": "mise exec node@24.16.0 -- npm run check:inner",
    "precheck:inner": "npm run generate-schemas --silent",
    "check:inner": "npm run sync:sdk-pin:check --silent && tsc --noEmit && npm run test:inner",
    "test": "mise exec node@24.16.0 -- npm run test:inner",
    "test:inner": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:tools-suite": "npm --prefix external/pi-tools-suite test",
    "sync:pi-tools-suite": "node scripts/sync-pi-tools-suite.mjs",
    "sync:pi-tools-suite:check": "node scripts/sync-pi-tools-suite.mjs --check",
    "sync:sdk-pin": "node scripts/sync-sdk-pin.mjs",
    "sync:sdk-pin:check": "node scripts/sync-sdk-pin.mjs --check",
    "test:coverage": "mise exec node@24.16.0 -- node --import tsx --test --experimental-test-coverage --test-coverage-include=src/**/*.ts --test-coverage-exclude=src/main.ts --test-coverage-lines=94 --test-coverage-branches=80 --test-coverage-functions=94 \"tests/**/*.test.ts\"",
    "update-sdk-references": "mise exec node@24.16.0 -- node .pi/skills/pi-sdk/scripts/update-references.mjs",
    "prepack": "npm run generate-schemas --silent",
    "pack:dry-run": "npm pack --dry-run",
    "smoke-test": "mise exec node@24.16.0 -- bash scripts/smoke-test-package.sh",
    "release:check": "npm run check && npm run build:pix && npm run pack:dry-run",
    "publish-npm": "bash scripts/publish.sh",
    "generate-schemas": "tsx scripts/generate-schemas.ts",
    "generate-schemas:check": "tsx scripts/generate-schemas.ts --check",
    "generate-schemas:watch": "tsx watch scripts/generate-schemas.ts",
    "prepublishOnly": "npm run check && npm run build:pix && npm run generate-schemas"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.10",
    "@earendil-works/pi-coding-agent": "0.80.10",
    "@earendil-works/pi-tui": "0.80.10",
    "@mariozechner/clipboard": "^0.3.9",
    "jsonc-parser": "3.3.1",
    "typebox": "1.1.38",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.22.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0 <25"
  },
  "overrides": {
    "get-uv-event-loop-napi-h": "1.0.6",
    "node-addon-api": "8.8.0"
  },
  "optionalDependencies": {
    "vosk": "0.3.39"
  },
  "keywords": [
    "pi",
    "pix",
    "coding-agent",
    "terminal",
    "renderer"
  ]
}
