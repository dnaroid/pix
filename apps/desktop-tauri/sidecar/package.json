{
  "name": "pix-desktop-sidecar",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Node SDK bridge for Pix Desktop. Hosts the Pi coding-agent SDK and exposes JSON-RPC over stdio to the Tauri Rust host.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.77.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "tsx": "4.22.1",
    "typescript": "5.9.3"
  }
}
