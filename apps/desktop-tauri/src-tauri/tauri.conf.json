{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pix",
  "version": "0.0.1",
  "identifier": "com.earendil-works.pix-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pix",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop UI for the Pi coding agent.",
    "longDescription": "Pix Desktop is a Tauri-based desktop UI for the Pi coding agent, providing workspace-scoped sessions, tool-call visualization, and integrated shell access outside the terminal."
  }
}
